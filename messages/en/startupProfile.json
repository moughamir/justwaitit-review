        "accessories": "Accessories",
        "jewelry": "Jewelry",
        "kaftan": "Modern Kaftan",
        "jellaba": "Contemporary Jellaba",
        "other": "Other"
      }
    },
    "stage": {
      "label": "Brand Stage",
      "options": {
        "concept": "Concept/Pre-launch",
